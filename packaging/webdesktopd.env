# webdesktopd environment configuration
# This file is sourced by both systemd (EnvironmentFile) and OpenRC.
# Lines starting with # are comments.

# Listening address (default: :8080)
#WEBDESKTOPD_ADDR=:8080

# JWT secret — set a strong random value in production.
# Generate one with: openssl rand -hex 32
#JWT_SECRET=

# SSH address used for credential validation (default: localhost:22)
#SSH_ADDR=localhost:22
